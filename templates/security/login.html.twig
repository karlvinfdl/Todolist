{# Page de connexion – autonome, n'étend pas base.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion – TaskTracker</title>
    {# Feuille de style dédiée à la page connexion #}
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
    {{ importmap('app') }}
</head>
<body>

<div class="login-page">

    {# Logo centré au-dessus de la carte #}
    <div class="login-logo">
        <img src="{{ asset('images/logo.png') }}" alt="TaskTracker">
    </div>

    {# Carte principale de connexion #}
    <div class="login-card">
        <h1>Connexion</h1>
        <p class="login-subtitle">Bon retour ! Entrez vos identifiants.</p>

        {# Affichage de l'erreur d'authentification si présente #}
        {% if error %}
            <div class="login-alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post">

            {# Champ adresse email #}
            <div class="login-field">
                <label for="inputEmail">Adresse email</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail"
                       placeholder="example@gmail.com" autocomplete="email" required autofocus>
            </div>

            {# Champ mot de passe #}
            <div class="login-field">
                <label for="inputPassword">Mot de passe</label>
                <input type="password" name="password" id="inputPassword"
                       autocomplete="current-password" required>
            </div>

            {# Lien mot de passe oublié #}
            <a href="#" class="login-forgot">Mot de passe oublié ?</a>

            {# Jeton CSRF pour sécuriser le formulaire #}
            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn-submit">Se connecter</button>
        </form>

        {# Liens bas de carte : inscription et retour accueil #}
        <div class="login-footer-links">
            <span>Pas encore de compte ? <a href="{{ path('app_register') }}">S'inscrire</a></span>
            <a href="{{ path('app_accueil') }}" class="login-back">← Retour à l'accueil</a>
        </div>
    </div>

</div>

</body>
</html>
