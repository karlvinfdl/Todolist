{% extends 'base.html.twig' %}

{% block title %}TaskTracker – Gérez vos tâches en toute simplicité{% endblock %}

{% block body %}
<section class="hero">
    <h1 class="hero-title">Bienvenue sur <strong>TaskTracker</strong></h1>
    <p class="hero-subtitle">Gérez vos tâches en toute simplicité.</p>

    <div class="hero-buttons">
        <a href="{{ path('app_login') }}" class="btn-login">Se connecter</a>
        <a href="{{ path('app_register') }}" class="btn-register">S'inscrire</a>
    </div>

    <img src="{{ asset('images/image_1.png') }}" alt="Illustration TaskTracker" class="hero-image">
</section>

{# ===== AVIS ===== #}
<section class="reviews-section">
    <div class="reviews">
        {% for a in avis %}
        <div class="review-card">
            <div class="review-avatar">{{ a.nom|first|upper }}</div>
            <div class="review-info">
                <span class="review-name">{{ a.nom }}</span>
                <div class="review-stars">
                    {% for i in 1..5 %}
                        <span class="{{ i <= a.note ? 'star-filled' : 'star-empty' }}">★</span>
                    {% endfor %}
                </div>
                <span class="review-date">{{ a.createdAt|date('M Y') }}</span>
                {% if a.commentaire %}
                <span class="review-comment">"{{ a.commentaire }}"</span>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
</section>

{% endblock %}
