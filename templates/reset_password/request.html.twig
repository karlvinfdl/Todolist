{# Page mot de passe oublié – autonome, n'étend pas base.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mot de passe oublié – TaskTracker</title>
    <link rel="stylesheet" href="{{ asset('styles/register.css') }}">
    {{ importmap('app') }}
</head>
<body>

<div class="register-page">

    <div class="register-logo">
        <img src="{{ asset('images/logo.png') }}" alt="TaskTracker">
    </div>

    <div class="register-card">
        <h1>Mot de passe oublié</h1>
        <p class="register-subtitle">Entrez votre email pour recevoir un lien de réinitialisation.</p>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="register-alert">{{ flash_error }}</div>
        {% endfor %}

        {{ form_start(requestForm, { attr: { novalidate: 'novalidate' } }) }}

            <div class="register-field">
                {{ form_label(requestForm.email, 'Adresse email') }}
                {{ form_widget(requestForm.email, { attr: { placeholder: 'example@gmail.com' } }) }}
                {{ form_errors(requestForm.email) }}
            </div>

            <button type="submit" class="btn-submit">Envoyer le lien</button>

        {{ form_end(requestForm) }}

        <div class="register-footer-link">
            Vous vous souvenez ? <a href="{{ path('app_login') }}">Se connecter</a>
        </div>
    </div>

</div>

</body>
</html>
