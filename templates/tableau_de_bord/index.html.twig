{# Page tableau de bord – autonome, n'étend pas base.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tableau de bord – TaskTracker</title>
    <link rel="stylesheet" href="{{ asset('styles/tableau_de_bord.css') }}">
    {{ importmap('app') }}
</head>
<body>

<div class="dashboard">

    {# ===== NAVBAR ===== #}
    <nav class="dash-navbar">
        <img src="{{ asset('images/logo.png') }}" alt="TaskTracker" class="dash-navbar-logo">

        <div class="dash-search">
            <div class="dash-search-inner">
                <input type="text" id="searchInput" placeholder="Rechercher..." oninput="rechercherTaches(this.value)">
                <svg viewBox="0 0 24 24"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
            </div>
        </div>

        <div class="dash-navbar-actions">
            <button class="btn-nouvelle-tache" onclick="ouvrirPanel()">
                Nouvelle tâche <span class="plus">+</span>
            </button>
            <div class="dash-avatar">
                <svg viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
            </div>
        </div>
    </nav>

    {# ===== ZONE PRINCIPALE ===== #}
    <div class="dash-main">

        {# ===== SIDEBAR ===== #}
        <aside class="dash-sidebar">

            <nav class="sidebar-nav">
                <a href="#" class="active" onclick="filtrer('toutes', null, 'Mes Tâches'); setActif(this); return false;">Mes Tâches</a>
            </nav>

            <div class="sidebar-section">
                <div class="sidebar-section-title">Projets</div>
                <div class="sidebar-projects">
                    {% for project in projects %}
                        <a href="#" class="sidebar-project"
                           onclick="filtrer('projet', '{{ project.id }}', '{{ project.name }}'); setActif(this); return false;">
                            <span class="project-dot" style="background: {{ project.color }};"></span>
                            {{ project.name }}
                        </a>
                    {% endfor %}
                </div>
                <a href="#" class="sidebar-new-project" onclick="ouvrirPanelProjet(); return false;">Nouveau projet +</a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-section-title">Catégories</div>
                <div class="sidebar-categories">
                    <a href="#" class="sidebar-category" onclick="filtrer('statut', 'a_faire', 'A faire'); setActif(this); return false;">
                        <span class="project-dot" style="background: #ef4444;"></span>A faire
                    </a>
                    <a href="#" class="sidebar-category" onclick="filtrer('statut', 'en_cours', 'En cours'); setActif(this); return false;">
                        <span class="project-dot" style="background: #eab308;"></span>En cours
                    </a>
                    <a href="#" class="sidebar-category" onclick="filtrer('statut', 'terminee', 'Terminé'); setActif(this); return false;">
                        <span class="project-dot" style="background: #22c55e;"></span>Terminé
                    </a>
                </div>
            </div>

            <div class="sidebar-footer">
                <a href="{{ path('app_logout') }}" class="btn-deconnexion">Déconnexion</a>
            </div>

        </aside>

        {# ===== CONTENU ===== #}
        <main class="dash-content">

            <h1 class="dash-content-title" id="contentTitre">Mes Tâches</h1>

            {# Cartes statistiques (toujours visibles) #}
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-card-label">Total tâches</div>
                    <div class="stat-card-value bleu">{{ stats.total }}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-label">A faire</div>
                    <div class="stat-card-value rouge">{{ stats.a_faire }}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-label">En cours</div>
                    <div class="stat-card-value jaune">{{ stats.en_cours }}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-label">Terminées</div>
                    <div class="stat-card-value vert">{{ stats.terminee }}</div>
                </div>
            </div>

            <div class="tasks-section-title" id="tasksSectionTitle">Tâches d'aujourd'hui</div>

            {# Liste des tâches – chaque carte a des data-attributes pour le filtrage JS #}
            <div class="tasks-list" id="tasksList">

                {% for task in tasks %}
                <div class="task-card"
                     data-project="{{ task.project.id }}"
                     data-statut="{{ task.status }}"
                     data-today="{{ task.dueDate ? (task.dueDate|date('Y-m-d') == 'now'|date('Y-m-d') ? '1' : '0') : (task.createdAt|date('Y-m-d') == 'now'|date('Y-m-d') ? '1' : '0') }}"
                     data-titre="{{ task.title|lower }}">

                    {# Checkbox statut #}
                    <form method="post" action="{{ path('app_tache_statut', {id: task.id}) }}" class="task-checkbox-form">
                        <input type="hidden" name="status" value="{{ task.status == 'terminee' ? 'a_faire' : 'terminee' }}">
                        <input type="checkbox" class="task-checkbox" onchange="this.form.submit()" {{ task.status == 'terminee' ? 'checked' : '' }}>
                    </form>

                    {# Titre + meta #}
                    <div class="task-info">
                        <div class="task-title {{ task.status == 'terminee' ? 'terminee' : '' }}">{{ task.title }}</div>
                        <div class="task-meta">
                            <span class="project-dot" style="background: {{ task.project.color }};"></span>
                            <span>{{ task.project.name }}</span>
                            <span>·</span>
                            {% if task.dueDate %}
                                {% if task.dueDate.format('Y-m-d') < 'now'|date('Y-m-d') and task.status != 'terminee' %}
                                    <span class="task-late">En retard {{ task.dueDate|date('d M') }}</span>
                                {% else %}
                                    <span>{{ task.dueDate|date('d M') }}</span>
                                {% endif %}
                            {% else %}
                                <span>Aujourd'hui</span>
                            {% endif %}
                        </div>
                    </div>

                    {# Badges #}
                    <div class="task-badges">
                        {% if task.status == 'terminee' %}
                            <span class="badge badge-terminee">Terminées</span>
                        {% elseif task.status == 'en_cours' %}
                            <span class="badge badge-en-cours">En cours</span>
                        {% else %}
                            <span class="badge badge-a-faire">A faire</span>
                        {% endif %}
                        {% if task.priority == 'haute' %}
                            <span class="badge badge-haute">Haute</span>
                        {% elseif task.priority == 'basse' %}
                            <span class="badge badge-basse">Basse</span>
                        {% else %}
                            <span class="badge badge-moyenne">Moyenne</span>
                        {% endif %}
                    </div>

                    {# Bouton éditer #}
                    <button class="btn-edit" title="Modifier">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
                        </svg>
                    </button>

                    {# Bouton supprimer #}
                    <form method="post" action="{{ path('app_tache_supprimer', {id: task.id}) }}">
                        <button type="submit" class="btn-suppr">Suppr.</button>
                    </form>

                </div>
                {% endfor %}

                <div class="tasks-empty" id="tasksEmpty" style="display:none;">Aucune tâche trouvée.</div>
            </div>

        </main>
    </div>

    {# ===== FOOTER ===== #}
    <footer class="dash-footer">
        <div class="dash-footer-top">
            <div class="dash-footer-links">
                <a href="#">Politique de confidentialité</a>
                <a href="#">Conditions d'utilisation</a>
            </div>
            <div class="dash-footer-social">
                <span>Suivez-nous!</span>
                <div class="dash-social-icons">
                    <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
                    <a href="#" aria-label="Twitter"><svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 5.882zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
                    <a href="#" aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
                    <a href="#" aria-label="LinkedIn"><svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
                </div>
            </div>
        </div>
        <div class="dash-footer-bottom">&copy; 2026 TaskTracker – Tous droits réservés</div>
    </footer>

</div>

{# ===== PANEL NOUVEAU PROJET ===== #}
<div class="panel-overlay" id="panelOverlayProjet" onclick="fermerPanelProjet()"></div>
<div class="panel-nouvelle-tache" id="panelNouveauProjet">
    <div class="panel-header">
        <h2>Nouveau projet</h2>
        <button class="btn-fermer-panel" onclick="fermerPanelProjet()">✕</button>
    </div>
    <form method="post" action="{{ path('app_projet_creer') }}">
        <div class="panel-field">
            <label for="projetNom">Nom <span class="requis">*</span></label>
            <input type="text" id="projetNom" name="name" placeholder="Nom du projet..." required>
        </div>
        <div class="panel-field">
            <label for="projetCouleur">Couleur</label>
            <input type="color" id="projetCouleur" name="color" value="#3B82F6" style="height:42px; padding:4px 8px; cursor:pointer;">
        </div>
        <div class="panel-footer">
            <button type="submit" class="btn-enregistrer">Créer</button>
            <button type="button" class="btn-annuler" onclick="fermerPanelProjet()">Annuler</button>
        </div>
    </form>
</div>

{# ===== PANEL NOUVELLE TÂCHE ===== #}
<div class="panel-overlay" id="panelOverlay" onclick="fermerPanel()"></div>
<div class="panel-nouvelle-tache" id="panelNouvelleTache">
    <div class="panel-header">
        <h2>Nouvelle tâche</h2>
        <button class="btn-fermer-panel" onclick="fermerPanel()">✕</button>
    </div>
    <form method="post" action="{{ path('app_tache_creer') }}">
        <div class="panel-field">
            <label for="tacheTitle">Titre <span class="requis">*</span></label>
            <input type="text" id="tacheTitle" name="title" placeholder="Nom de la tâche..." required>
        </div>
        <div class="panel-field">
            <label for="tacheDesc">Description</label>
            <textarea id="tacheDesc" name="description" placeholder="Ajouter une description..."></textarea>
        </div>
        <div class="panel-field">
            <label for="tacheProjet">Projet</label>
            <select id="tacheProjet" name="project_id" required>
                {% for project in projects %}
                    <option value="{{ project.id }}">{{ project.name }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="panel-field">
            <label for="tacheStatut">Statut</label>
            <select id="tacheStatut" name="status">
                <option value="a_faire">A faire</option>
                <option value="en_cours">En cours</option>
                <option value="terminee">Terminée</option>
            </select>
        </div>
        <div class="panel-field">
            <label for="tachePriorite">Priorité</label>
            <select id="tachePriorite" name="priority">
                <option value="basse">Basse</option>
                <option value="moyenne" selected>Moyenne</option>
                <option value="haute">Haute</option>
            </select>
        </div>
        <div class="panel-field">
            <label for="tacheDate">Date d'échéance</label>
            <input type="date" id="tacheDate" name="dueDate">
        </div>
        <div class="panel-footer">
            <button type="submit" class="btn-enregistrer">Enregistrer</button>
            <button type="button" class="btn-annuler" onclick="fermerPanel()">Annuler</button>
        </div>
    </form>
</div>

<script>
    /* ===== Panels ===== */
    function ouvrirPanel() {
        document.getElementById('panelNouvelleTache').classList.add('ouvert');
        document.getElementById('panelOverlay').classList.add('ouvert');
    }
    function fermerPanel() {
        document.getElementById('panelNouvelleTache').classList.remove('ouvert');
        document.getElementById('panelOverlay').classList.remove('ouvert');
    }
    function ouvrirPanelProjet() {
        document.getElementById('panelNouveauProjet').classList.add('ouvert');
        document.getElementById('panelOverlayProjet').classList.add('ouvert');
    }
    function fermerPanelProjet() {
        document.getElementById('panelNouveauProjet').classList.remove('ouvert');
        document.getElementById('panelOverlayProjet').classList.remove('ouvert');
    }

    /* ===== Lien actif sidebar ===== */
    function setActif(el) {
        document.querySelectorAll('.sidebar-nav a, .sidebar-project, .sidebar-category').forEach(function(e) {
            e.classList.remove('active');
        });
        el.classList.add('active');
    }

    /* ===== Filtrage des tâches ===== */
    var modeActuel = 'aujourd_hui';
    var valeurActuelle = null;

    function filtrer(mode, valeur, titre) {
        modeActuel = mode;
        valeurActuelle = valeur;
        document.getElementById('contentTitre').textContent = titre;

        var sous = { 'aujourd_hui': "Tâches d'aujourd'hui", 'toutes': 'Toutes les tâches', 'projet': 'Tâches du projet', 'statut': 'Tâches' };
        document.getElementById('tasksSectionTitle').textContent = sous[mode] || 'Tâches';

        appliquerFiltres(document.getElementById('searchInput').value);
    }

    function appliquerFiltres(recherche) {
        var cartes = document.querySelectorAll('.task-card');
        var visible = 0;
        recherche = recherche.toLowerCase().trim();

        cartes.forEach(function(carte) {
            var ok = true;

            /* Filtre par mode */
            if (modeActuel === 'aujourd_hui') {
                ok = carte.dataset.today === '1';
            } else if (modeActuel === 'projet') {
                ok = carte.dataset.project === valeurActuelle;
            } else if (modeActuel === 'statut') {
                ok = carte.dataset.statut === valeurActuelle;
            }
            /* 'toutes' = pas de filtre */

            /* Filtre par recherche */
            if (ok && recherche !== '') {
                ok = carte.dataset.titre.includes(recherche);
            }

            carte.style.display = ok ? 'flex' : 'none';
            if (ok) visible++;
        });

        /* Message si aucune tâche */
        document.getElementById('tasksEmpty').style.display = visible === 0 ? 'block' : 'none';
    }

    function rechercherTaches(valeur) {
        appliquerFiltres(valeur);
    }

    /* Au chargement : afficher les tâches d'aujourd'hui, ou toutes si aucune aujourd'hui */
    window.addEventListener('DOMContentLoaded', function() {
        filtrer('toutes', null, 'Mes Tâches');
    });
</script>

</body>
</html>
