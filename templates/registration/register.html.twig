{# Page d'inscription – autonome, n'étend pas base.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription – TaskTracker</title>
    {# Feuille de style dédiée à la page inscription #}
    <link rel="stylesheet" href="{{ asset('styles/register.css') }}">
    {{ importmap('app') }}
</head>
<body>

<div class="register-page">

    {# Logo centré au-dessus de la carte #}
    <div class="register-logo">
        <img src="{{ asset('images/logo.png') }}" alt="TaskTracker">
    </div>

    {# Carte principale d'inscription #}
    <div class="register-card">
        <h1>Créer un compte</h1>
        <p class="register-subtitle">Commencez à gérer vos tâches dès maintenant.</p>

        {# Affichage des erreurs globales du formulaire #}
        {% if registrationForm.vars.errors|length %}
            <div class="register-alert">
                {{ form_errors(registrationForm) }}
            </div>
        {% endif %}

        {{ form_start(registrationForm, { attr: { novalidate: 'novalidate' } }) }}

            {# Champ adresse email #}
            <div class="register-field">
                {{ form_label(registrationForm.email, 'Adresse email') }}
                {{ form_widget(registrationForm.email) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            {# Champ mot de passe #}
            <div class="register-field">
                {{ form_label(registrationForm.plainPassword.first) }}
                {{ form_widget(registrationForm.plainPassword.first) }}
                {{ form_errors(registrationForm.plainPassword.first) }}
            </div>

            {# Champ confirmation du mot de passe #}
            <div class="register-field">
                {{ form_label(registrationForm.plainPassword.second) }}
                {{ form_widget(registrationForm.plainPassword.second) }}
                {{ form_errors(registrationForm.plainPassword.second) }}
            </div>

            {# Jeton CSRF géré automatiquement par form_start #}

            <button type="submit" class="btn-submit">Créer mon compte</button>

        {{ form_end(registrationForm) }}

        {# Lien vers la page de connexion #}
        <div class="register-footer-link">
            Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
        </div>
    </div>

</div>

</body>
</html>
