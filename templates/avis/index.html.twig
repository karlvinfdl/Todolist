<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laisser un avis – TaskTracker</title>
    <link rel="stylesheet" href="{{ asset('styles/avis.css') }}">
    {{ importmap('app') }}
</head>
<body>

<div class="avis-page">

    <div class="avis-logo">
        <img src="{{ asset('images/logo.png') }}" alt="TaskTracker">
    </div>

    <div class="avis-card">
        <h1>Votre avis</h1>
        <p class="avis-subtitle">Partagez votre expérience avec TaskTracker</p>

        <form action="{{ path('app_avis_soumettre') }}" method="POST">

            <div class="avis-field">
                <label for="nom">Votre prénom</label>
                <input type="text" id="nom" name="nom" placeholder="ex : Sophie" required autocomplete="given-name">
            </div>

            <div class="avis-field">
                <label>Note</label>
                <div class="stars-selector">
                    <input type="radio" id="star5" name="note" value="5" checked>
                    <label for="star5">★</label>
                    <input type="radio" id="star4" name="note" value="4">
                    <label for="star4">★</label>
                    <input type="radio" id="star3" name="note" value="3">
                    <label for="star3">★</label>
                    <input type="radio" id="star2" name="note" value="2">
                    <label for="star2">★</label>
                    <input type="radio" id="star1" name="note" value="1">
                    <label for="star1">★</label>
                </div>
            </div>

            <div class="avis-field">
                <label for="commentaire">Commentaire</label>
                <textarea id="commentaire" name="commentaire" placeholder="Décrivez votre expérience..." required></textarea>
            </div>

            <button type="submit" class="btn-submit">Envoyer mon avis</button>

        </form>

        <div class="avis-footer-links">
            <a href="{{ path('app_accueil') }}" class="avis-back">← Retour à l'accueil</a>
        </div>
    </div>

</div>

</body>
</html>
